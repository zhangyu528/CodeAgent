{
  "name": "codeagent",
  "version": "1.0.0",
  "description": "This is a new project initialized with Gemini CLI.",
  "main": "dist/index.js",
  "bin": {
    "codeagent": "dist/apps/cli/index.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "node --loader ts-node/esm --experimental-specifier-resolution=node src/apps/cli/index.ts",
    "start": "node --loader ts-node/esm --experimental-specifier-resolution=node src/apps/cli/index.ts",
    "pkg:win": "bun build ./dist/apps/kernel/index.js --compile --target bun-windows-x64 --outfile binaries/codeagent-kernel-win.exe",
    "pkg:mac": "bun build ./dist/apps/kernel/index.js --compile --target bun-darwin-arm64 --outfile binaries/codeagent-kernel-macos-arm64",
    "test:integration": "node --loader ts-node/esm/transpile-only --experimental-specifier-resolution=node src/tests/integration/index.ts",
    "test:security": "node --loader ts-node/esm/transpile-only --experimental-specifier-resolution=node src/tests/security/path_guard.test.ts",
    "test:e2e": "node --loader ts-node/esm/transpile-only --experimental-specifier-resolution=node src/tests/e2e/comprehensive_workflow.test.ts",
    "test:all": "npm run test:unit && npm run test:security && npm run test:integration && npm run test:e2e",
    "test": "npm run test:all",
    "test:unit": "node --loader ts-node/esm/transpile-only --experimental-specifier-resolution=node src/tests/unit/index.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhangyu528/CodeAgent.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/zhangyu528/CodeAgent/issues"
  },
  "homepage": "https://github.com/zhangyu528/CodeAgent#readme",
  "dependencies": {
    "@inquirer/prompts": "^7.10.1",
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "log-update": "^6.1.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "ora": "^5.4.1",
    "typescript": "^5.9.3",
    "zod": "^4.3.6",
    "react": "^18.3.1",
    "ink": "^5.2.1"
  },
  "devDependencies": {
    "@types/chalk": "^0.4.31",
    "@types/commander": "^2.12.0",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^25.4.0",
    "@types/ora": "^3.1.0",
    "ts-node": "^10.9.2",
    "@types/react": "^18.3.12"
  },
  "type": "module"
}