#!/bin/bash
# Git post-commit hook
# 当 git commit 完成后自动发送变更报告到飞书

PROJECT_DIR="/mnt/d/work/project/CodeAgent"
cd "$PROJECT_DIR"

# 获取当前 commit 信息
COMMIT_MSG=$(git log -1 --pretty=%B | head -20)
COMMIT_HASH=$(git log -1 --pretty=%h)
COMMIT_TIME=$(git log -1 --pretty=%ci | cut -d' ' -f1,2 | sed 's/+08:00//')
BRANCH=$(git branch --show-current)

# 获取变更统计
FILES_CHANGED=$(git diff --cached --name-only | wc -l)
INSERTIONS=$(git diff --cached --numstat | awk '{add += $1} END {print add}')
DELETIONS=$(git diff --cached --numstat | awk '{del += $2} END {print del}')

# 获取变更文件列表
FILES=$(git diff --cached --name-only | head -30)
REMAINING=0
if [ $(git diff --cached --name-only | wc -l) -gt 30 ]; then
    REMAINING=$(( $(git diff --cached --name-only | wc -l) - 30 ))
    FILES="$FILES
... 还有 ${REMAINING} 个文件"
fi

# 分类统计
NEW_FILES=$(git diff --cached --name-only --diff-filter=A | wc -l)
MODIFIED_FILES=$(git diff --cached --name-only --diff-filter=M | wc -l)
DELETED_FILES=$(git diff --cached --name-only --diff-filter=D | wc -l)

# 分类文件
SRC_CHANGES=$(git diff --cached --name-only | grep -E "^src/" | wc -l)
TEST_CHANGES=$(git diff --cached --name-only | grep -E "^tests/" | wc -l)
SCRIPT_CHANGES=$(git diff --cached --name-only | grep -E "^scripts/" | wc -l)

# 生成报告
REPORT="📝 Git Commit 报告

💾 commit: ${COMMIT_HASH}
📋 分支: ${BRANCH}
⏰ 时间: ${COMMIT_TIME}

━━━━━━━━━━━━━━━━━━━━━━━

📊 变更统计:
• 文件数: ${FILES_CHANGED} 个
• 新增: ${NEW_FILES} 个
• 修改: ${MODIFIED_FILES} 个
• 删除: ${DELETED_FILES} 个
• +${INSERTIONS} / -${DELETIONS} 行

📁 变更分类:
• 源代码: ${SRC_CHANGES} 个
• 测试文件: ${TEST_CHANGES} 个
• 脚本: ${SCRIPT_CHANGES} 个

📝 Commit 消息:
${COMMIT_MSG}

━━━━━━━━━━━━━━━━━━━━━━━
变更文件:
${FILES}
"

echo "$REPORT"

# 发送到飞书
FEISHU_WEBHOOK_URL=$(grep "FEISHU_WEBHOOK_URL" "$PROJECT_DIR/scripts/.env" | cut -d'=' -f2)

if [ -n "$FEISHU_WEBHOOK_URL" ]; then
    # 使用 Python 进行 JSON 转义
    ESCAPED_REPORT=$(python3 -c "import json,sys; print(json.dumps(sys.stdin.read().strip()))" <<< "$REPORT")
    JSON_PAYLOAD="{\"msg_type\":\"text\",\"content\":{\"text\":${ESCAPED_REPORT}}}"
    
    curl -s -X POST "$FEISHU_WEBHOOK_URL" \
        -H "Content-Type: application/json" \
        -d "$JSON_PAYLOAD" \
        > /tmp/feishu_response.txt
    echo ""
    if grep -q '"code":0' /tmp/feishu_response.txt 2>/dev/null; then
        echo "✅ 已发送到飞书"
    else
        echo "❌ 发送失败: $(cat /tmp/feishu_response.txt)"
    fi
else
    echo "❌ 未配置 FEISHU_WEBHOOK_URL"
fi

# 记录日志
echo "[$(date)] Commit ${COMMIT_HASH} reported" >> "$PROJECT_DIR/scripts/git_hooks/hook.log"
