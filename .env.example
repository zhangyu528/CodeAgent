# --- OpenAI ---
# 必填：用于 Pi Agent Core 的主要模型
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# --- Anthropic ---
# 可选：如果您想切换到 Claude 模型
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# --- 其他 Pi AI 支持的 Provider (按需配置) ---
# DEEPSEEK_API_KEY=...
# GOOGLE_GENERATIVE_AI_API_KEY=...

# 注：旧版的 WEB_SEARCH_PROVIDER, STATUS_BAR, DIFF_CONFIRM 等配置已不再需要。
