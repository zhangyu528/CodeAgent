# GLM provider API key for chat/embeddings
GLM_API_KEY=your_api_key
# GLM chat model name (e.g., glm-4.7)
GLM_MODEL=your_model_name
# GLM base URL (chat + embeddings endpoints)
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Service API key for /run (Authorization: Bearer <key> or X-API-Key). If unset, /run is open.
SERVER_API_KEY=your_server_api_key
# Request-level timeout for /run (ms)
REQUEST_TIMEOUT_MS=60000
# Maximum concurrent /run requests
MAX_CONCURRENCY=2
# Optional log file path for request logs
LOG_FILE_PATH=./logs/server.log

# Toggle logging of tool_call/tool_result
LOG_TOOL_CALLS=false
# Planning mode: off | on | auto
PLANNING_MODE=off
