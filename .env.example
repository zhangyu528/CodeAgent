# Default provider used at startup. Must be one of the registered providers.
# Examples: glm | openai | anthropic | deepseek | ollama
DEFAULT_PROVIDER=glm

# --- GLM (Zhipu AI) ---
GLM_API_KEY=your_glm_api_key_here
GLM_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
# Optional (legacy). If omitted, falls back to DEFAULT_MODEL_NAME then glm-4.
GLM_MODEL=glm-4

# --- OpenAI ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Web (F5)
# Choose provider: tavily | serpapi
WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=your_tavily_api_key_here
# Optional override
TAVILY_API_URL=https://api.tavily.com/search

SERPAPI_API_KEY=your_serpapi_api_key_here
SERPAPI_API_URL=https://serpapi.com/search.json

# Optional: Safe proxy fetch endpoint. If set, CodeAgent will call:
# - if WEB_PROXY_URL contains {url}: WEB_PROXY_URL.replace('{url}', encodeURIComponent(target))
# - else: WEB_PROXY_URL + '?url=' + encodeURIComponent(target)
WEB_PROXY_URL=
WEB_USER_AGENT=CodeAgent/1.0
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# --- DeepSeek ---
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# --- Ollama (Local) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Legacy / misc
DEFAULT_MODEL_NAME=glm-4
MAX_ITERATIONS=10
