# 默认 Provider（zai 或 minimax）
DEFAULT_PROVIDER=zai

# --- Zhipu GLM (provider: zai) ---
ZAI_API_KEY=your_zhipu_api_key_here
# 覆盖默认模型（默认: glm-4.7）
ZAI_MODEL=glm-4.7
# 覆盖 API 类型（默认使用 pi-ai registry 中的类型）
# ZAI_API=openai-completions
# 覆盖 baseURL（默认使用 pi-ai registry 中的 URL）
# ZAI_BASE_URL=https://api.zhipuai.cn/v1

# --- Minimax (provider: minimax) ---
MINIMAX_API_KEY=your_minimax_api_key_here
# 覆盖默认模型（默认: MiniMax-M2.7）
MINIMAX_MODEL=MiniMax-M2.7
# 覆盖 API 类型（默认使用 pi-ai registry 中的类型）
MINIMAX_API=openai-completions
# 覆盖 baseURL（默认使用 pi-ai registry 中的 URL）
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
