#!/usr/bin/env python3
"""Git Post-Commit Hook - 每次提交后发送报告到飞书"""
import subprocess, os, sys
from pathlib import Path

PROJECT_DIR = Path(__file__).parent.parent
sys.path.insert(0, str(PROJECT_DIR / "scripts"))
from feishu_webhook import send_text_message

ENV_FILE = PROJECT_DIR / "scripts" / ".env"

def get_env(key):
    if ENV_FILE.exists():
        for line in open(ENV_FILE):
            line = line.strip()
            if line and not line.startswith("#") and "=" in line:
                k, v = line.split("=", 1)
                if k.strip() == key:
                    return v.strip().strip('"').strip("'")
    return os.getenv(key, "")

def get_git_info():
    branch = subprocess.run(["git", "branch", "--show-current"], capture_output=True, text=True).stdout.strip() or "?"
    result = subprocess.run(["git", "log", "-1", "--format=%h|%s|%an|%ae|%ct"], capture_output=True, text=True)
    parts = result.stdout.strip().split("|") if result.returncode == 0 else []
    hash_, subject, author, email, timestamp = (parts + ["?", "无", "?", "?", "0"])[:5]
    files = subprocess.run(["git", "diff", "--name-only", "HEAD~1..HEAD"], capture_output=True, text=True).stdout.strip().split("\n")
    diff_stat = subprocess.run(["git", "diff", "--stat", "HEAD~1..HEAD"], capture_output=True, text=True).stdout.strip()
    return {"branch": branch, "hash": hash_, "subject": subject, "author": author, "timestamp": timestamp, "files": [f for f in files if f], "diff_stat": diff_stat}

def main():
    import datetime
    webhook_url = get_env("FEISHU_WEBHOOK_URL")
    if not webhook_url:
        print("❌ 未设置 FEISHU_WEBHOOK_URL")
        return
    info = get_git_info()
    ts = datetime.datetime.fromtimestamp(int(info.get("timestamp", 0)))
    msg = f"📝 Git 提交报告\n\n⏰ {ts.strftime('%Y-%m-%d %H:%M')}\n🌿 分支: {info['branch']}\n📌 提交: {info['hash']}\n\n━━━━━━━━━━━━━━━━━━━━━━━\n\n💬 {info['subject']}\n\n👤 {info['author']}\n📁 {len(info['files'])} 文件改动\n\n"
    for f in info['files'][:10]:
        msg += f"• {f}\n"
    if len(info['files']) > 10:
        msg += f"... 还有 {len(info['files']) - 10} 个文件\n"
    if info['diff_stat']:
        msg += f"\n📊 改动统计：\n{info['diff_stat']}\n"
    msg += "━━━━━━━━━━━━━━━━━━━━━━━"
    print(msg)
    result = send_text_message(webhook_url, msg)
    print(f"✅ 已发送到飞书: {result}")

if __name__ == "__main__":
    main()
