{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "esnext",
    "target": "esnext",
    "types": [
      "node"
    ],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "verbatimModuleSyntax": false,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler"
  },
  "exclude": [
    "src/tests/**/*",
    "dist"
  ]
}